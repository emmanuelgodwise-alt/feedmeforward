generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core User Model ───────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String
  displayName    String?
  bio            String?
  avatarUrl      String?
  role           String   @default("member") // member, creator, moderator, admin
  memberScore    Int      @default(0)
  walletBalance  Float    @default(0.0)
  isVerified     Boolean  @default(false)
  onboardingCompleted Boolean @default(false)
  // Business & Creator
  businessName        String?
  businessCategory    String?
  businessEmail       String?
  businessWebsite     String?
  businessBio         String?
  subscriptionTiers   String?            @default("[]") // JSON: [{tier, name, price, benefits}]
  analytics           CreatorAnalytics?  @relation("CreatorAnalytics")
  subscriptions       Subscription[]     @relation("CreatorSubscriptions")
  subscriberOf        Subscription[]     @relation("UserSubscriptions")
  promotedVideos      PromotedVideo[]    @relation("UserPromotedVideos")
  // Audience Segmentation
  ageRange       String?
  location       String?
  gender         String?
  language       String?
  interests      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  videos            Video[]         @relation("UserVideos")
  pollVotes         PollVote[]      @relation("UserPollVotes")
  followers         Follow[]        @relation("UserFollowers")
  following         Follow[]        @relation("UserFollowing")
  transactions      Transaction[]   @relation("UserTransactions")
  comments          Comment[]
  commentLikes      CommentLike[]   @relation("UserCommentLikes")
  likes             Like[]          @relation("UserLikes")
  savedVideos        SavedVideo[]    @relation("UserSavedVideos")
  invitations       Invitation[]    @relation("UserInvitations")
  createdCircles    Circle[]        @relation("CircleCreator")
  circleMemberships CircleMember[]  @relation("UserCircleMemberships")
  circleShares      CircleVideo[]
  liveSessions      LiveSession[]   @relation("LiveSessionCreator")
  livePolls         LivePoll[]     @relation("UserLivePolls")
  livePollVotes     LivePollVote[] @relation("UserLivePollVotes")
  liveViewers       LiveViewer[]   @relation("UserLiveViewers")
  reports           Report[]        @relation("UserReports")
  segments          AudienceSegment[] @relation("UserAudienceSegments")
  notifications     Notification[]  @relation("UserNotifications")
  sentNotifications Notification[]  @relation("NotificationSender")
  conversations     ConversationMember[]
  sentMessages      Message[]       @relation("SentMessages")
  voiceCalls        VoiceCall[]
  videoCalls        VideoCall[]
  blockedUsers      BlockedUser[]   @relation("BlockedUsers")
  blockedByUsers    BlockedUser[]   @relation("BlockedByUsers")
  reactions         Reaction[]      @relation("UserReactions")
  reposts           Repost[]        @relation("UserReposts")
  stories           Story[]         @relation("UserStories")
}

// ─── Video Model ────────────────────────────────────────────────────
model Video {
  id           String   @id @default(cuid())
  creatorId    String
  type         String   @default("lead") // "lead" or "response"
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  category     String?
  tags         String?  // JSON string of tags array
  status       String   @default("active") // "active", "expired", "answered"
  duration     Int?     // video duration in seconds
  viewCount    Int      @default(0)
  isPublic     Boolean  @default(true)
  isTextOnly   Boolean  @default(false) // text-only response, no video
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      User       @relation("UserVideos", fields: [creatorId], references: [id])
  polls        Poll[]
  comments     Comment[]
  likes        Like[]
  savedBy      SavedVideo[]
  reports      Report[]
  invitations     Invitation[]
  circleShares    CircleVideo[]
  notifications   Notification[]  @relation("NotificationVideo")
  videoHashtags   VideoHashtag[]

  reactions    Reaction[]   @relation("VideoReactions")
  reposts      Repost[]     @relation("VideoReposts")
  promotedVideo       PromotedVideo?    @relation("PromotedVideos")

  // Self-referential for response clips
  parentVideoId String?
  parentVideo   Video?    @relation("VideoResponses", fields: [parentVideoId], references: [id])
  responses     Video[]   @relation("VideoResponses")
}

// ─── Hashtag Model ──────────────────────────────────────────────────
model Hashtag {
  id        String   @id @default(cuid())
  tag       String   @unique // lowercase tag without #
  useCount  Int      @default(0)
  createdAt DateTime @default(now())

  videoHashtags VideoHashtag[]
}

// ─── VideoHashtag Join Model ─────────────────────────────────────────
model VideoHashtag {
  id        String   @id @default(cuid())
  videoId   String
  hashtagId String
  createdAt DateTime @default(now())

  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([videoId, hashtagId])
}

// ─── Poll Model ─────────────────────────────────────────────────────
model Poll {
  id                 String    @id @default(cuid())
  videoId            String
  question           String
  options            String    // JSON string: [{id, text, voteCount}]
  targetingCriteria  String?   // JSON string: {age, location, gender, language, minScore, etc.}
  isPaid             Boolean   @default(false)
  rewardPerResponse  Float?    // payment per response for paid polls
  totalRewardPool    Float?
  maxResponses       Int?
  responseCount      Int       @default(0)
  closesAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  video Video       @relation(fields: [videoId], references: [id], onDelete: Cascade)
  votes PollVote[]
}

// ─── PollVote Model ─────────────────────────────────────────────────
model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  optionId  String   // the selected option ID
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id])
  user User @relation("UserPollVotes", fields: [userId], references: [id])

  @@unique([pollId, userId]) // one vote per user per poll
}

// ─── Follow Model ───────────────────────────────────────────────────
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── Transaction Model ──────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   // "tip", "withdrawal", "deposit", "earning", "reward"
  status      String   @default("pending") // "pending", "completed", "failed"
  description String?
  referenceId String?  // ID of related entity (video, poll, etc.)
  createdAt   DateTime @default(now())

  user User @relation("UserTransactions", fields: [userId], references: [id])
}

// ─── Comment Model ──────────────────────────────────────────────────
model Comment {
  id              String   @id @default(cuid())
  userId          String
  videoId         String
  content         String
  parentCommentId String?  // for nested replies
  isVideoReply    Boolean  @default(false) // video reply to comment
  videoReplyUrl   String?  // URL of the video reply
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  video         Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  likes         CommentLike[]
  reports       Report[]
}

// ─── CommentLike Model ──────────────────────────────────────────────
model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User     @relation("UserCommentLikes", fields: [userId], references: [id])

  @@unique([commentId, userId])
}

// ─── Like Model (Video Likes) ───────────────────────────────────────
model Like {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// ─── Saved Video Model (Bookmark) ───────────────────────────────────────
model SavedVideo {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation("UserSavedVideos", fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// ─── Invitation Model ───────────────────────────────────────────────
model Invitation {
  id           String    @id @default(cuid())
  inviterId    String
  inviteeEmail String
  videoId      String?
  status       String    @default("sent") // "sent", "clicked", "responded", "expired"
  rewardGiven  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  respondedAt  DateTime?

  inviter User  @relation("UserInvitations", fields: [inviterId], references: [id])
  video  Video? @relation(fields: [videoId], references: [id])
}

// ─── Circle Model ───────────────────────────────────────────────────
model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  creatorId   String
  isPublic    Boolean  @default(true)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User          @relation("CircleCreator", fields: [creatorId], references: [id])
  members CircleMember[]
  videos  CircleVideo[]
}

// ─── CircleMember Model ─────────────────────────────────────────────
model CircleMember {
  id       String   @id @default(cuid())
  circleId String
  userId   String
  role     String   @default("member") // "member", "moderator", "admin"
  joinedAt DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation("UserCircleMemberships", fields: [userId], references: [id])

  @@unique([circleId, userId])
}

// ─── CircleVideo Model ──────────────────────────────────────────────
model CircleVideo {
  id        String   @id @default(cuid())
  circleId  String
  videoId   String
  sharedBy  String
  createdAt DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  video  Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [sharedBy], references: [id])

  @@unique([circleId, videoId])
}

// ─── LiveSession Model ──────────────────────────────────────────────
model LiveSession {
  id              String    @id @default(cuid())
  creatorId       String
  title           String
  description     String?
  status          String    @default("upcoming") // "upcoming", "live", "ended", "recording"
  thumbnailUrl    String?
  category        String?
  tags            String?   // JSON string of tags array
  viewerCount     Int       @default(0)
  peakViewers     Int       @default(0)
  totalViewCount  Int       @default(0)
  startedAt       DateTime?
  endedAt         DateTime?
  scheduledAt     DateTime?
  duration        Int?      // seconds, calculated on end
  isRecorded      Boolean   @default(false)
  recordedVideoId String?
  chatEnabled     Boolean   @default(true)
  pollsEnabled    Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  creator          User               @relation("LiveSessionCreator", fields: [creatorId], references: [id])
  polls            LivePoll[]
  chatMessages     LiveChatMessage[]
  viewers          LiveViewer[]
}

// ─── LivePoll Model ─────────────────────────────────────────────────
model LivePoll {
  id          String    @id @default(cuid())
  sessionId   String
  creatorId   String
  question    String
  options     String    // JSON string: [{text, voteCount}]
  totalVotes  Int       @default(0)
  status      String    @default("active") // "active", "closed"
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  session LiveSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  creator User            @relation("UserLivePolls", fields: [creatorId], references: [id])
  votes   LivePollVote[]
}

// ─── LivePollVote Model ─────────────────────────────────────────────
model LivePollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll LivePoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User     @relation("UserLivePollVotes", fields: [userId], references: [id])

  @@unique([pollId, userId])
}

// ─── LiveChatMessage Model ──────────────────────────────────────────
model LiveChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  username    String
  displayName String?
  avatarUrl   String?
  content     String
  createdAt   DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── LiveViewer Model ───────────────────────────────────────────────
model LiveViewer {
  id           String   @id @default(cuid())
  sessionId    String
  userId       String
  joinedAt     DateTime @default(now())
  lastActiveAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation("UserLiveViewers", fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

// ─── Report Model ───────────────────────────────────────────────────
model Report {
  id          String    @id @default(cuid())
  reporterId  String
  videoId     String?
  commentId   String?
  reason      String    // "offensive", "spam", "misleading", "other"
  description String?
  status      String    @default("pending") // "pending", "reviewing", "resolved", "dismissed"
  juryVotes   String?   // JSON string: [{userId, vote, createdAt}]
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  reporter User    @relation("UserReports", fields: [reporterId], references: [id])
  video    Video?  @relation(fields: [videoId], references: [id])
  comment  Comment? @relation(fields: [commentId], references: [id])
}

// ─── Notification Model ───────────────────────────────────────────
model Notification {
  id          String   @id @default(cuid())
  userId      String   // user who receives the notification
  fromUserId  String?  // user who triggered the notification
  type        String   // "follow", "like", "comment", "response", "poll_vote", "mention", "invitation_accepted", "tip"
  title       String?
  message     String?
  videoId     String?
  commentId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user     User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUser User?    @relation("NotificationSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  video    Video?   @relation("NotificationVideo", fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Conversation Model ──────────────────────────────────────
model Conversation {
  id             String    @id @default(cuid())
  type           String    @default("direct") // "direct" | "group"
  name           String?
  avatarUrl      String?
  lastMessage    String?
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members    ConversationMember[]
  messages   Message[]
  voiceCalls VoiceCall[]
  videoCalls VideoCall[]

  @@index([lastActivityAt])
}

// ─── Conversation Member Model ──────────────────────────────────
model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String   @default("member") // "admin" | "member"
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

// ─── Message Model ──────────────────────────────────────────────
model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  type           String   @default("text") // "text" | "image" | "video" | "voice" | "file" | "system"
  content        String?
  mediaUrl       String?
  replyToId      String?
  isRead         Boolean  @default(false)
  readBy         String?  // JSON array of user IDs who read this
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Voice Call Model ───────────────────────────────────────────
model VoiceCall {
  id             String    @id @default(cuid())
  conversationId String
  callerId       String
  status         String    @default("ringing") // "ringing" | "ongoing" | "ended" | "rejected"
  startedAt      DateTime?
  endedAt        DateTime?
  duration       Int?      // Duration in seconds
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  caller       User         @relation(fields: [callerId], references: [id])

  @@index([conversationId])
}

// ─── Video Call Model ───────────────────────────────────────────
model VideoCall {
  id             String    @id @default(cuid())
  conversationId String
  callerId       String
  status         String    @default("ringing") // "ringing" | "ongoing" | "ended" | "rejected"
  startedAt      DateTime?
  endedAt        DateTime?
  duration       Int?      // Duration in seconds
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  caller       User         @relation(fields: [callerId], references: [id])

  @@index([conversationId])
}

// ─── Call Signal Model (WebRTC Signaling) ───────────────────────
model CallSignal {
  id         String   @id @default(cuid())
  callId     String
  callType   String   // "voice" | "video"
  signalType String   // "offer" | "answer" | "ice-candidate" | "hangup"
  senderId   String
  content    String   // JSON string for SDP or ICE candidate
  createdAt  DateTime @default(now())

  @@index([callId, createdAt])
}

// ─── Blocked User Model ────────────────────────────────────────
model BlockedUser {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  reason      String?
  createdAt   DateTime @default(now())

  blocker User @relation("BlockedUsers", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedByUsers", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

// ─── Reaction Model (Multi-emoji) ────────────────────────────────────
model Reaction {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  type      String   // 'fire', 'heart', 'laugh', 'wow', 'sad', 'angry', 'clap', 'thinking'
  createdAt DateTime @default(now())
  user      User  @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)
  video     Video @relation("VideoReactions", fields: [videoId], references: [id], onDelete: Cascade)
  @@unique([userId, videoId, type])
  @@index([videoId, type])
}

// ─── Repost Model ───────────────────────────────────────────────────
model Repost {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  quote       String?
  createdAt   DateTime @default(now())
  user        User  @relation("UserReposts", fields: [userId], references: [id], onDelete: Cascade)
  video       Video @relation("VideoReposts", fields: [videoId], references: [id], onDelete: Cascade)
  @@unique([userId, videoId])
  @@index([userId, createdAt])
}

// ─── Story Model (Ephemeral Content) ─────────────────────────────────
model Story {
  id          String   @id @default(cuid())
  creatorId   String
  videoUrl    String?
  imageUrl    String?
  text        String?
  type        String   @default("text") // 'text', 'image', 'video'
  viewers     String   @default("[]")
  viewCount   Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  creator     User  @relation("UserStories", fields: [creatorId], references: [id], onDelete: Cascade)
  @@index([creatorId, createdAt])
  @@index([expiresAt])
}

// ─── Creator Analytics Model ──────────────────────────────────────
model CreatorAnalytics {
  id            String   @id @default(cuid())
  creatorId     String   @unique
  totalViews    Int      @default(0)
  totalLikes    Int      @default(0)
  totalComments Int      @default(0)
  totalResponses Int     @default(0)
  totalTips     Float    @default(0.0)
  totalRevenue  Float    @default(0.0)
  totalPolls    Int      @default(0)
  avgEngagement Float    @default(0.0)
  topCategory   String?
  subscriberCount Int    @default(0)
  period        String   @default("all") // 'all', '7d', '30d', '90d'
  computedAt    DateTime @default(now())
  creator       User     @relation("CreatorAnalytics", fields: [creatorId], references: [id], onDelete: Cascade)
}

// ─── Promoted Video Model ──────────────────────────────────────────
model PromotedVideo {
  id            String   @id @default(cuid())
  videoId       String   @unique
  creatorId     String
  budget        Float
  spent         Float    @default(0.0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  status        String   @default("active") // 'active', 'paused', 'exhausted', 'expired'
  targetingCriteria String? // JSON string, same format as poll targeting
  startsAt      DateTime @default(now())
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  video         Video    @relation("PromotedVideos", fields: [videoId], references: [id])
  creator       User     @relation("UserPromotedVideos", fields: [creatorId], references: [id], onDelete: Cascade)
  @@index([status, startsAt])
}

// ─── Subscription Model ────────────────────────────────────────────
model Subscription {
  id            String   @id @default(cuid())
  subscriberId  String
  creatorId     String
  tier          String   @default("basic") // 'basic', 'premium', 'exclusive'
  amount        Float
  status        String   @default("active") // 'active', 'cancelled', 'expired'
  startedAt     DateTime @default(now())
  expiresAt     DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  subscriber    User     @relation("UserSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
  creator       User     @relation("CreatorSubscriptions", fields: [creatorId], references: [id], onDelete: Cascade)
  @@unique([subscriberId, creatorId])
  @@index([creatorId, status])
}

// ─── Audience Segment Model ─────────────────────────────────────────
model AudienceSegment {
  id          String   @id @default(cuid())
  creatorId   String
  name        String
  description String?
  criteria    String
  userCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation("UserAudienceSegments", fields: [creatorId], references: [id])
}
